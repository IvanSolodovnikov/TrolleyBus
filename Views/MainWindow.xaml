<Window x:Class="TrolleybusApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Trolleybus" Height="400" Width="700">

    <StackPanel>

        <Button Content="Добавить троллейбус"
                Click="Add_Click"
                Margin="10"/>

        <ItemsControl ItemsSource="{Binding Items}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding Status}" />

                        <!-- ДВИЖЕНИЕ -->
                        <Canvas Grid.Column="1" Height="30" Background="LightGray">
                            <Ellipse Width="20" Height="20" Fill="Blue">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform X="{Binding Position}" />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Canvas>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </StackPanel>
</Window>